# ── Server ───────────────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0

# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/darwin_db

# ── LLM Providers ────────────────────────────────────────────────────────────
# Set your active provider
LLM_PROVIDER=openai     # options: openai, google-genai, anthropic
LLM_MODEL=gpt-4o-mini   # suggested sizes: gpt-4o-mini, gemini-2.5-flash, claude-3-haiku-20240307

# Provide the API key for your chosen provider:
OPENAI_API_KEY=sk-your-openai-key-here
GEMINI_API_KEY=your-google-gemini-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ── JWT (must match connector-service) ───────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=5

# ── App ───────────────────────────────────────────────────────────────────────
# Options: development | test | production
ENVIRONMENT=development
